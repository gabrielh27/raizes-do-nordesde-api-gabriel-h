	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "T01 - Login Admin (valido)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
									"var json = pm.response.json();",
									"pm.test('Retornou access_token', function () { pm.expect(json).to.have.property('access_token'); });",
									"pm.collectionVariables.set('token_admin', json.access_token);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n  \"email\": \"admin@teste.com\",\n  \"senha\": \"admin123\"\n}"},
						"url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]}
					}
				},
				{
					"name": "T02 - Login Cliente (valido)",
